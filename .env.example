# Copy to .env and edit. docker compose reads it automatically.

# Host port for the API (container always listens on 8000 internally).
MEMEX_PORT=8000

# Optional bearer token. Set this for any deployment past localhost.
# Generate one with: openssl rand -hex 32
MEMEX_API_TOKEN=

# Only needed if memex.yaml uses provider: openai with the cloud endpoint.
OPENAI_API_KEY=

# (The Dockerfile bakes every model the runtime needs — ChromaDB ONNX MiniLM,
# HuggingFace sentence-transformers MiniLM, fastembed Qdrant/bm25, spaCy
# en_core_web_sm, tiktoken cl100k_base — into the image. No build-time
# toggle: the container is offline-ready out of the box.)

# Defaults written to ./data/memex.yaml on first start. Ignored once the file
# exists. Override here to point a fresh deployment at a different LLM /
# user_id without editing the YAML by hand.
#MEMEX_DEFAULT_USER_ID=guolin
#MEMEX_DEFAULT_LLM_MODEL=qwen3:4b
#MEMEX_DEFAULT_LLM_BASE_URL=http://10.242.29.48:11434/v1
#MEMEX_DEFAULT_LLM_API_KEY=no-key
