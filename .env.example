# Copy to .env and edit. docker compose reads it automatically.

# Host port for the API (container always listens on 8000 internally).
MEMEX_PORT=8000

# Optional bearer token. Set this for any deployment past localhost.
# Generate one with: openssl rand -hex 32
MEMEX_API_TOKEN=

# Only needed if memex.yaml uses provider: openai with the cloud endpoint.
OPENAI_API_KEY=

# Bake offline models into the image so the container starts with NO network
# calls. 1 (default) = ~1.4 GB image with chromadb ONNX + sentence-transformers
# + CPU torch. 0 = ~500 MB slim image, requires runtime model download (only
# safe if you'll exclusively use the openai cloud profile).
WITH_LOCAL_MODELS=1
