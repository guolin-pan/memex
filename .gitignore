# Real secrets live in .env (committed: .env.example template only).
.env
.env.local
.env.*.local

# uv.lock IS committed when you use uv as the canonical lockfile so the
# install is reproducible. Uncomment below if you want to ignore it.
# uv.lock

# Generated agent transcripts / terminal dumps (Cursor uses /tmp paths).
*.transcript.md
