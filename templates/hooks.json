{
  "hooks": {
    "sessionStart": [
      {
        "name": "memex-profile",
        "command": "memex mem profile --write /tmp/cursor-memex-profile.md"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "name": "memex-ctx",
        "command": "memex ctx \"$CURSOR_USER_PROMPT\" --write /tmp/cursor-memex-ctx.md --budget 2000"
      }
    ],
    "sessionEnd": [
      {
        "name": "memex-learn",
        "command": "memex mem learn --from-cursor-transcript --category learning"
      }
    ]
  }
}
