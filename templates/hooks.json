{
  "hooks": {
    "sessionStart": [
      {
        "name": "memex-profile",
        "command": "memex client mem profile --write /tmp/cursor-memex-profile.md"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "name": "memex-ctx",
        "command": "memex client ctx \"$CURSOR_USER_PROMPT\" --write /tmp/cursor-memex-ctx.md --budget 2000"
      }
    ]
  }
}
