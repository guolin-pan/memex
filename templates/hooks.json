{
  "hooks": {
    "sessionStart": [
      {
        "name": "memex-profile",
        "command": "$HOME/.cursor/agents/memex-client.py mem profile --write /tmp/cursor-memex-profile.md"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "name": "memex-ctx",
        "command": "$HOME/.cursor/agents/memex-client.py ctx \"$CURSOR_USER_PROMPT\" --write /tmp/cursor-memex-ctx.md --budget 2000"
      }
    ]
  }
}
